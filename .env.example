# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# Admin (seed only — required for npm run db:seed)
ADMIN_PASSWORD="choose-a-strong-admin-password"

# PIX (public — shown on pending payment page)
NEXT_PUBLIC_PIX_KEY="sua-chave-pix-aqui"
NEXT_PUBLIC_ENTRY_FEE="50.00"

# Football API (football-data.org v4 — free tier: 10 req/min)
FOOTBALL_DATA_API_KEY="sua-chave-da-api-de-futebol-aqui"

# Cron / automation (Vercel crons + GitHub Actions — Bearer token for /api/cron/*)
CRON_SECRET="generate-a-long-random-secret-here"

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"

# Optional: distributed rate limiting (Upstash Redis REST)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
