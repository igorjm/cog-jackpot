generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  nickname  String     @unique
  status    UserStatus @default(PENDING_PAYMENT)
  role      Role       @default(USER)
  bets      Bet[]
  bonusBets BonusBet[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum UserStatus {
  PENDING_PAYMENT
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
}

model Match {
  id          String   @id @default(cuid())
  homeTeam    String
  awayTeam    String
  homeFlag    String
  awayFlag    String
  phase       Phase
  group       String?
  matchNumber Int      @unique
  matchDate   DateTime
  venue       String?
  homeScore   Int?
  awayScore   Int?
  multiplier  Float    @default(1.0)
  bets        Bet[]
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Phase {
  GROUP
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

model Bet {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  homeScore Int
  awayScore Int
  points    Int?
  rawPoints Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
}

model BonusBet {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  phase        Phase
  selectedTeam String
  isCorrect    Boolean?
  points       Int?
  createdAt    DateTime @default(now())

  @@unique([userId, phase, selectedTeam])
}

model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
