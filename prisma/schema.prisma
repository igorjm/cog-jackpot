generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  password          String
  nickname          String             @unique
  avatar            String?
  status            UserStatus         @default(PENDING_PAYMENT)
  role              Role               @default(USER)
  previousPosition  Int?
  bets              Bet[]
  bonusBets         BonusBet[]
  predictions       Prediction[]
  pushSubscriptions PushSubscription[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum UserStatus {
  PENDING_PAYMENT
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  TIMED
  IN_PLAY
  PAUSED
  FINISHED
  SUSPENDED
  POSTPONED
  CANCELLED
  AWARDED
}

model Match {
  id            String       @id @default(cuid())
  homeTeam      String
  awayTeam      String
  homeFlag      String
  awayFlag      String
  phase         Phase
  group         String?
  matchNumber   Int          @unique
  matchDate     DateTime
  venue         String?
  homeScore     Int?
  awayScore     Int?
  liveHomeScore Int?
  liveAwayScore Int?
  halfTimeHome  Int?
  halfTimeAway  Int?
  liveGoals     Json?
  matchStatus   MatchStatus  @default(SCHEDULED)
  liveUpdatedAt DateTime?
  multiplier    Float        @default(1.0)
  bets          Bet[]
  isLocked      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum Phase {
  FRIENDLY
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

model Bet {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  homeScore Int
  awayScore Int
  points    Float?
  rawPoints Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
}

model BonusBet {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  phase        Phase
  selectedTeam String
  isCorrect    Boolean?
  points       Int?
  createdAt    DateTime @default(now())

  @@unique([userId, phase, selectedTeam])
}

model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prediction {
  id        String         @id @default(cuid())
  user      User           @relation(fields: [userId], references: [id])
  userId    String
  type      PredictionType
  value     String
  isCorrect Boolean?
  points    Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, type])
}

enum PredictionType {
  CHAMPION
  TOP_SCORER
}
